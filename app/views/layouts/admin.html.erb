<!DOCTYPE html>
<html lang="es">
<head>
  <title>Backoffice — Proyecto API</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; margin: 0; background: #f5f6f8; color: #1f2937; }
    header { background: #111827; padding: 0.75rem 1.5rem; }
    header a { color: #f9fafb; text-decoration: none; font-weight: 600; font-size: 1.1rem; }
    main { max-width: 60rem; margin: 1.5rem auto; padding: 0 1rem; }
    h2 { margin-top: 0; }
    table { width: 100%; border-collapse: collapse; background: #fff; }
    th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #e5e7eb; }
    th { background: #f3f4f6; }
    a { color: #2563eb; }
    .actions { margin: 1rem 0; }
    .btn { display: inline-block; background: #2563eb; color: #fff; padding: 0.4rem 0.9rem;
           border: 0; border-radius: 4px; text-decoration: none; cursor: pointer; }
    .field { margin-bottom: 0.9rem; }
    .field label { display: block; font-weight: 600; margin-bottom: 0.25rem; }
    .field input, .field select, .field textarea { width: 100%; padding: 0.4rem;
           border: 1px solid #d1d5db; border-radius: 4px; font-family: inherit; }
    .field textarea { font-family: monospace; }
    .errors { background: #fef2f2; border: 1px solid #dc2626; color: #991b1b;
              padding: 0.75rem 1rem; border-radius: 4px; margin-bottom: 1rem; }
    .errors ul { margin: 0; padding-left: 1.2rem; }
    pre { background: #f3f4f6; padding: 0.75rem; border-radius: 4px; overflow-x: auto; }
  </style>
</head>
<body>
  <header><%= link_to 'Backoffice — Plantillas de APIs', admin_services_path %></header>
  <main><%= yield %></main>
</body>
</html>
