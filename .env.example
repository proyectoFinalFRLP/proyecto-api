# Copiar a .env y completar. En test/CI, DEVISE_JWT_SECRET_KEY cae por defecto
# a Rails.application.secret_key_base si no está seteada.

# Clave secreta para firmar los JWT. Generar con: rails secret
DEVISE_JWT_SECRET_KEY=

# Password del rol de PostgreSQL en desarrollo.
PROYECTO_API_DATABASE_PASSWORD=admin
